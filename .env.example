# clio-store runtime environment variables.
# Copy to .env and fill in, or run `pixi run setup`.

# --- Required ------------------------------------------------------------

# DatasetGateway base URL. clio-store delegates all auth/authz here.
DSG_URL=https://dataset-gateway.janelia.org

# Email that automatically receives global "admin" privileges.
OWNER=you@example.com

# --- Optional ------------------------------------------------------------

# Prefix prepended to every API endpoint, e.g. "/api" → /api/v2/datasets
URL_PREFIX=

# CORS Access-Control-Allow-Origin. "*" or comma-separated origins.
ALLOWED_ORIGINS=*

# GCS bucket holding image signatures (powers /v2/signatures).
SIG_BUCKET=

# Cloud Function URL for /v2/transfer.
TRANSFER_FUNC=

# Destination cache for image transfers.
TRANSFER_DEST=

# Path to a GCP service-account JSON. Required for local dev (Cloud Run
# uses workload identity automatically).
GOOGLE_APPLICATION_CREDENTIALS=
